{
  "name": "remjs",
  "version": "0.3.0",
  "description": "Event loop replication — serialize JS program execution as structured ops",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/build-mirror.mjs",
    "build:mirror": "node scripts/build-mirror.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:todo": "node examples/todo/server.js",
    "example:dashboard": "node examples/dashboard/server.js"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
